rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isChatMember(chatId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/chats/$(chatId)) &&
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /listings/{listingId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /chats/{chatId} {

      // ✅ FIXED: Simplified for real-time compatibility
      // Use signedIn() for all read operations to handle:
      // - Collection queries with arrayContains
      // - Single document listens  
      // - Query-order-by scenarios
      allow read, list: if signedIn();

      allow create: if signedIn()
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;

      allow update: if signedIn()
        && request.auth.uid in resource.data.participants;

      allow delete: if signedIn()
        && request.auth.uid in resource.data.participants;
    }

    match /chats/{chatId}/messages/{messageId} {

      allow read: if signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

      allow update: if signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

      allow delete: if signedIn()
        && resource.data.senderId == request.auth.uid;
    }

    match /notifications/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /support/{id} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow read: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /email_otps/{id} {
      allow read, write: if false;
    }

    match /rate_limits/{id} {
      allow read, write: if false;
    }
  }
}